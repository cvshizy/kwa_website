# Sanity Configuration
# Get these values from https://sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: For draft content preview
SANITY_API_READ_TOKEN=your_read_token

# Site Runtime Configuration (dual deployment)
# global or cn
NEXT_PUBLIC_SITE_REGION=global
# public site origin used for sitemap/robots/metadata
NEXT_PUBLIC_SITE_URL=https://kwmartcenter.com
# contact form endpoint (global/cn can be different)
NEXT_PUBLIC_CONTACT_FORM_ACTION=https://formspree.io/f/xbdabrdw

# Sanity webhook secret for on-demand revalidation
SANITY_REVALIDATE_SECRET=change_me_to_a_long_random_string
